  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "lint": "tsc --noEmit",
    "vercel-build": "vite build"
  },
  "dependencies": {
